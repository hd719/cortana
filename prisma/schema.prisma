generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["partialIndexes"]
}

datasource db {
  provider = "postgresql"
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model cortana_action_policies {
  id                  BigInt   @id @default(autoincrement())
  policy_key          String   @unique
  category            String
  description         String?
  base_decision       String
  requires_approval   Boolean  @default(false)
  risk_base           Decimal  @default(0) @db.Decimal(5, 2)
  risk_threshold_ask  Decimal  @default(65) @db.Decimal(5, 2)
  risk_threshold_deny Decimal  @default(90) @db.Decimal(5, 2)
  immutable           Boolean  @default(false)
  constraints         Json     @default("{}")
  enabled             Boolean  @default(true)
  created_at          DateTime @default(now()) @db.Timestamptz(6)
  updated_at          DateTime @default(now()) @db.Timestamptz(6)

  @@index([category, enabled], map: "idx_action_policies_category_enabled")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
/// This model contains an expression index which requires additional setup for migrations. Visit https://pris.ly/d/expression-indexes for more info.
model cortana_agent_feedback {
  id                 Int               @id @default(autoincrement())
  agent_role         String
  feedback_text      String
  source_feedback_id Int?
  source_task_id     Int?
  confidence         Decimal           @default(0.80) @db.Decimal(3, 2)
  active             Boolean           @default(true)
  created_at         DateTime          @default(now()) @db.Timestamptz(6)
  updated_at         DateTime          @default(now()) @db.Timestamptz(6)
  cortana_feedback   cortana_feedback? @relation(fields: [source_feedback_id], references: [id], onUpdate: NoAction)
  cortana_tasks      cortana_tasks?    @relation(fields: [source_task_id], references: [id], onUpdate: NoAction)

  @@index([active], map: "idx_cortana_agent_feedback_active")
  @@index([agent_role], map: "idx_cortana_agent_feedback_role")
  @@index([agent_role, active], map: "idx_cortana_agent_feedback_role_active")
}

model cortana_autonomy_incidents {
  id                  BigInt   @id @default(autoincrement())
  timestamp           DateTime @default(now()) @db.Timestamptz(6)
  incident_type       String
  source              String?
  auto_resolved       Boolean  @default(false)
  escalated_to_human  Boolean  @default(false)
  resolution_time_sec Decimal? @db.Decimal(10, 2)
  metadata            Json     @default("{}")

  @@index([auto_resolved, escalated_to_human], map: "idx_autonomy_incidents_flags")
  @@index([timestamp(sort: Desc)], map: "idx_autonomy_incidents_ts")
}

model cortana_autonomy_scorecard_snapshots {
  id                         BigInt   @id @default(autoincrement())
  timestamp                  DateTime @default(now()) @db.Timestamptz(6)
  window_days                Int      @default(7)
  score                      Decimal  @db.Decimal(5, 2)
  self_heal_rate             Decimal  @db.Decimal(5, 2)
  proactive_hit_rate         Decimal  @db.Decimal(5, 2)
  task_completion_rate       Decimal  @db.Decimal(5, 2)
  correction_frequency_score Decimal  @db.Decimal(5, 2)
  response_quality_score     Decimal  @db.Decimal(5, 2)
  memory_accuracy            Decimal  @db.Decimal(5, 2)
  uptime_score               Decimal  @db.Decimal(5, 2)
  metrics                    Json     @default("{}")
  weights                    Json     @default("{}")

  @@index([timestamp(sort: Desc)], map: "idx_autonomy_snapshots_ts")
}

model cortana_budget_log {
  id            Int      @id @default(autoincrement())
  timestamp     DateTime @default(now()) @db.Timestamptz(6)
  spend_to_date Decimal? @db.Decimal(8, 2)
  burn_rate     Decimal? @db.Decimal(6, 2)
  projected     Decimal? @db.Decimal(8, 2)
  breakdown     Json?    @default("{}")
  pct_used      Decimal? @db.Decimal(5, 2)

  @@index([timestamp(sort: Desc)], map: "idx_budget_log_ts")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model cortana_budget_policies {
  id             BigInt   @id @default(autoincrement())
  budget_key     String   @unique
  cost_type      String
  scope          String   @default("global")
  scope_value    String?
  window_seconds Int
  limit_value    Decimal  @db.Decimal(14, 4)
  warn_at_pct    Decimal  @default(80) @db.Decimal(5, 2)
  hard_stop      Boolean  @default(true)
  on_exceed      String   @default("ask")
  metadata       Json     @default("{}")
  enabled        Boolean  @default(true)
  created_at     DateTime @default(now()) @db.Timestamptz(6)
  updated_at     DateTime @default(now()) @db.Timestamptz(6)

  @@index([cost_type, scope, enabled], map: "idx_budget_policies_type_scope_enabled")
}

model cortana_chaos_events {
  id                 Int                @id @default(autoincrement())
  run_id             String             @db.Uuid
  started_at         DateTime           @default(now()) @db.Timestamptz(6)
  scenario_name      String
  fault_type         String
  injected           Boolean            @default(true)
  detected           Boolean            @default(false)
  recovered          Boolean            @default(false)
  detection_ms       Int                @default(0)
  recovery_ms        Int                @default(0)
  notes              String?
  metadata           Json               @default("{}")
  cortana_chaos_runs cortana_chaos_runs @relation(fields: [run_id], references: [run_id], onDelete: Cascade, onUpdate: NoAction)

  @@index([fault_type, started_at(sort: Desc)], map: "idx_cortana_chaos_events_fault_type")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model cortana_chaos_runs {
  id                   Int                    @id @default(autoincrement())
  run_id               String                 @unique @db.Uuid
  started_at           DateTime               @default(now()) @db.Timestamptz(6)
  mode                 String                 @default("simulation")
  scenario_count       Int                    @default(0)
  status               String                 @default("running")
  metadata             Json                   @default("{}")
  cortana_chaos_events cortana_chaos_events[]

  @@index([started_at(sort: Desc)], map: "idx_cortana_chaos_runs_started_at")
}

model cortana_chief_model {
  key        String    @id @db.VarChar(50)
  value      Json
  updated_at DateTime? @default(now()) @db.Timestamptz(6)
  source     String?   @db.VarChar(50)
}

model cortana_council_events {
  id                       String                   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  session_id               String                   @db.Uuid
  event_type               String
  payload                  Json?                    @default("{}")
  created_at               DateTime                 @default(now()) @db.Timestamptz(6)
  cortana_council_sessions cortana_council_sessions @relation(fields: [session_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([session_id, created_at], map: "idx_council_events_session")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model cortana_council_sessions {
  id                     String                   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  created_at             DateTime                 @default(now()) @db.Timestamptz(6)
  updated_at             DateTime                 @default(now()) @db.Timestamptz(6)
  type                   String
  status                 String                   @default("open")
  title                  String
  context                Json                     @default("{}")
  initiator              String
  participants           String[]
  decision               Json?
  decided_at             DateTime?                @db.Timestamptz(6)
  expires_at             DateTime                 @db.Timestamptz(6)
  related_task_id        Int?
  model_policy           Json?                    @default("{\"voter_model\": \"openai/gpt-4o-mini\", \"synthesis_model\": \"anthropic/claude-sonnet-4-20250514\", \"session_budget_usd\": 0.05, \"max_tokens_per_vote\": 500}")
  metadata               Json?                    @default("{}")
  cortana_council_events cortana_council_events[]
  cortana_tasks          cortana_tasks?           @relation(fields: [related_task_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  cortana_council_votes  cortana_council_votes[]

  @@index([expires_at], map: "idx_council_sessions_expires", where: raw("(status = 'open'::text)"))
  @@index([status], map: "idx_council_sessions_status")
  @@index([type, status], map: "idx_council_sessions_type_status")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model cortana_council_votes {
  id                       String                   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  session_id               String                   @db.Uuid
  voter                    String
  vote                     String
  confidence               Float?
  reasoning                String?
  model_used               String?
  token_cost               Int?
  voted_at                 DateTime                 @default(now()) @db.Timestamptz(6)
  cortana_council_sessions cortana_council_sessions @relation(fields: [session_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([session_id, voter])
  @@index([session_id], map: "idx_council_votes_session")
}

model cortana_covenant_runs {
  id            Int       @id @default(autoincrement())
  agent         String    @db.VarChar(50)
  mission       String
  started_at    DateTime? @default(now()) @db.Timestamp(6)
  ended_at      DateTime? @db.Timestamp(6)
  status        String?   @default("running") @db.VarChar(20)
  tokens_used   Int?
  cost_estimate Decimal?  @db.Decimal(10, 4)
  budget_cap    Decimal?  @db.Decimal(10, 4)
  output_path   String?
  summary       String?
  session_key   String?   @db.VarChar(100)
}

model cortana_cron_health {
  id                   Int      @id @default(autoincrement())
  timestamp            DateTime @default(now()) @db.Timestamptz(6)
  cron_name            String
  status               String
  consecutive_failures Int?     @default(0)
  run_duration_sec     Decimal? @db.Decimal(8, 2)
  metadata             Json?    @default("{}")

  @@index([cron_name, timestamp(sort: Desc)], map: "idx_cron_health_name")
}

model cortana_decision_traces {
  id           BigInt    @id @default(autoincrement())
  trace_id     String    @unique(map: "idx_decision_traces_trace_id")
  event_id     BigInt?
  task_id      BigInt?
  run_id       String?
  trigger_type String
  action_type  String
  action_name  String
  reasoning    String?
  confidence   Decimal?  @db.Decimal(5, 4)
  outcome      String    @default("unknown")
  data_inputs  Json      @default("{}")
  metadata     Json      @default("{}")
  created_at   DateTime  @default(now()) @db.Timestamptz(6)
  completed_at DateTime? @db.Timestamptz(6)

  @@index([confidence], map: "idx_decision_traces_confidence")
  @@index([created_at(sort: Desc)], map: "idx_decision_traces_created_at")
  @@index([data_inputs], map: "idx_decision_traces_data_inputs", type: Gin)
  @@index([metadata], map: "idx_decision_traces_metadata", type: Gin)
  @@index([outcome], map: "idx_decision_traces_outcome")
  @@index([trigger_type, action_type], map: "idx_decision_traces_trigger_action")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model cortana_epics {
  id            Int             @id @default(autoincrement())
  title         String
  source        String?
  status        String?         @default("active")
  deadline      DateTime?       @db.Timestamptz(6)
  created_at    DateTime?       @default(now()) @db.Timestamptz(6)
  completed_at  DateTime?       @db.Timestamptz(6)
  metadata      Json?           @default("{}")
  cortana_tasks cortana_tasks[]

  @@index([status], map: "idx_cortana_epics_status")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model cortana_event_bus_events {
  id             BigInt   @id @default(autoincrement())
  created_at     DateTime @default(now()) @db.Timestamptz(6)
  event_type     String
  source         String
  payload        Json     @default("{}")
  correlation_id String?  @db.Uuid
  delivered      Boolean  @default(false)

  @@index([created_at(sort: Desc)], map: "idx_event_bus_events_created_at")
  @@index([event_type, created_at(sort: Desc)], map: "idx_event_bus_events_type_created")
}

model cortana_event_stream {
  id           Int       @id @default(autoincrement())
  timestamp    DateTime? @default(now()) @db.Timestamptz(6)
  source       String    @db.VarChar(50)
  event_type   String    @db.VarChar(50)
  payload      Json?     @default("{}")
  processed    Boolean?  @default(false)
  processed_at DateTime? @db.Timestamptz(6)

  @@index([source, timestamp(sort: Desc)], map: "idx_event_stream_source")
  @@index([processed, timestamp], map: "idx_event_stream_unprocessed", where: raw("(processed = false)"))
}

model cortana_events {
  id         Int       @id @default(autoincrement())
  timestamp  DateTime? @default(now()) @db.Timestamptz(6)
  event_type String?   @db.VarChar(50)
  source     String?   @db.VarChar(100)
  severity   String?   @db.VarChar(20)
  message    String?
  metadata   Json?

  @@index([source], map: "idx_events_source")
  @@index([timestamp], map: "idx_events_timestamp")
  @@index([event_type], map: "idx_events_type")
}

model cortana_feedback {
  id                     Int                      @id @default(autoincrement())
  timestamp              DateTime?                @default(now()) @db.Timestamptz(6)
  feedback_type          String?                  @db.VarChar(50)
  context                String?
  lesson                 String?
  applied                Boolean?                 @default(false)
  cortana_agent_feedback cortana_agent_feedback[]

  @@index([applied], map: "idx_feedback_applied")
  @@index([feedback_type], map: "idx_feedback_type")
}

model cortana_feedback_signals {
  id                 Int       @id @default(autoincrement())
  timestamp          DateTime? @default(now()) @db.Timestamptz(6)
  signal_type        String    @db.VarChar(20)
  source             String    @db.VarChar(50)
  related_rule       String?   @db.VarChar(100)
  related_message_id String?
