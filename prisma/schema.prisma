}

model cortana_handoff_artifacts {
  id            Int       @id @default(autoincrement())
  chain_id      String    @db.Uuid
  from_agent    String
  to_agent      String?
  artifact_type String
  payload       Json
  created_by    String    @default("cortana")
  consumed_at   DateTime? @db.Timestamptz(6)
  created_at    DateTime  @default(now()) @db.Timestamptz(6)

  @@index([chain_id], map: "idx_handoff_artifacts_chain_id")
  @@index([consumed_at], map: "idx_handoff_artifacts_consumed_at")
  @@index([from_agent], map: "idx_handoff_artifacts_from_agent")
  @@index([to_agent], map: "idx_handoff_artifacts_to_agent")
}

model cortana_immune_incidents {
  id               Int       @id @default(autoincrement())
  detected_at      DateTime  @default(now()) @db.Timestamptz(6)
  resolved_at      DateTime? @db.Timestamptz(6)
  threat_type      String
  source           String
  severity         String    @default("medium")
  description      String
  threat_signature String?
  tier             Int
  status           String    @default("detected")
  playbook_used    String?
  resolution       String?
  auto_resolved    Boolean?  @default(false)
  metadata         Json?     @default("{}")

  @@index([detected_at(sort: Desc)], map: "idx_immune_incidents_detected")
  @@index([threat_signature], map: "idx_immune_incidents_signature")
  @@index([status], map: "idx_immune_incidents_status", where: raw("(status <> 'resolved'::text)"))
}

model cortana_immune_playbooks {
  id               Int       @id @default(autoincrement())
  name             String    @unique
  threat_signature String
  description      String
  actions          Json
  tier             Int       @default(1)
  enabled          Boolean?  @default(true)
  times_used       Int?      @default(0)
  last_used        DateTime? @db.Timestamptz(6)
  success_rate     Decimal?  @default(1.0) @db.Decimal(4, 2)
  created_at       DateTime  @default(now()) @db.Timestamptz(6)
  updated_at       DateTime  @default(now()) @db.Timestamptz(6)

  @@index([threat_signature], map: "idx_immune_playbooks_signature")
}

model cortana_insights {
