{
  "name": "openclaw",
  "private": true,
  "packageManager": "pnpm@10.30.2",
  "scripts": {
    "build": "pnpm list --depth=0 > /dev/null",
    "test": "vitest run",
    "test:watch": "vitest",
    "smoke:post-merge": "pnpm exec vitest run tests/qa/validate-system.test.ts --no-file-parallelism",
    "ops:repo-hygiene": "bash tools/repo/repo-auto-sync.sh",
    "ops:post-merge": "bash tools/repo/post-pr-cleanup.sh",
    "ops:deploy-runtime": "bash tools/deploy/sync-runtime-from-cortana.sh",
    "repo:artifact-guard": "bash tools/repo/tracked-artifact-guard.sh",
    "ops:routing-drift": "pnpm exec tsx tools/monitoring/ops-routing-drift-check.ts",
    "release:done-gates": "pnpm exec tsx tools/release/done-gates.ts",
    "session:lifecycle": "pnpm exec tsx tools/session/session-lifecycle-policy.ts",
    "deploy:drift-warning": "bash tools/release/deploy-drift-warning.sh",
    "taskboard:integrity-guard": "pnpm exec tsx tools/task-board/integrity-guard.ts --pretty",
    "researcher:start": "bash tools/researcher/start-researcher.sh",
    "researcher:start:dry": "bash tools/researcher/start-researcher.sh --dry-run"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "tsx": "^4.6.0",
    "vitest": "^4.0.18"
  },
  "dependencies": {
    "@prisma/client": "^7.4.2",
    "dotenv": "^16.6.1",
    "prisma": "^7.4.2"
  }
}
