{
  "name": "openclaw",
  "private": true,
  "scripts": {
    "build": "npm ls --depth=0 > /dev/null",
    "test": "vitest run",
    "test:watch": "vitest",
    "smoke:post-merge": "npx vitest run tests/qa/validate-system.test.ts --no-file-parallelism",
    "release:done-gates": "npx tsx tools/release/done-gates.ts",
    "session:lifecycle": "npx --yes tsx tools/session/session-lifecycle-policy.ts",
    "deploy:drift-warning": "bash tools/release/deploy-drift-warning.sh",
    "taskboard:integrity-guard": "npx tsx tools/task-board/integrity-guard.ts --pretty",
    "researcher:start": "bash tools/researcher/start-researcher.sh",
    "researcher:start:dry": "bash tools/researcher/start-researcher.sh --dry-run"
  },
  "devDependencies": {
    "tsx": "^4.6.0",
    "vitest": "^4.0.18"
  },
  "dependencies": {
    "@prisma/client": "^7.4.2",
    "dotenv": "^16.6.1",
    "prisma": "^7.4.2"
  }
}
