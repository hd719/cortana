<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
  <dict>
    <key>Label</key>
    <string>com.cortana.insight-promotion</string>

    <key>ProgramArguments</key>
    <array>
      <string>/bin/zsh</string>
      <string>-lc</string>
      <string>cd /Users/hd/Developer/cortana &amp;&amp; /usr/bin/env python3 tools/memory/promote_insights.py scan --source session --since-hours 24 &amp;&amp; /usr/bin/env python3 tools/memory/promote_insights.py scan --source daily-notes --since-hours 24</string>
    </array>

    <key>StartCalendarInterval</key>
    <dict>
      <key>Hour</key>
      <integer>3</integer>
      <key>Minute</key>
      <integer>30</integer>
    </dict>

    <key>WorkingDirectory</key>
    <string>/Users/hd/Developer/cortana</string>

    <key>EnvironmentVariables</key>
    <dict>
      <key>PATH</key>
      <string>/opt/homebrew/bin:/opt/homebrew/opt/postgresql@17/bin:/usr/local/bin:/usr/bin:/bin</string>
    </dict>

    <key>RunAtLoad</key>
    <false/>

    <key>StandardOutPath</key>
    <string>/Users/hd/Developer/cortana/tmp/insight-promotion.stdout.log</string>
    <key>StandardErrorPath</key>
    <string>/Users/hd/Developer/cortana/tmp/insight-promotion.stderr.log</string>
  </dict>
</plist>
