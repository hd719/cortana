{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "types": ["node"],
    "allowImportingTsExtensions": true,
    "moduleDetection": "force",
    "strict": false,
    "noEmit": true,
    "outDir": "dist",
    "rootDir": "."
  },
  "include": [
    "tools/**/*.ts"
  ],
  "exclude": [
    "tools/fitness/**/*.ts",
    "tools/memory/**/*.ts",
    "tools/trading/**/*.ts",
    "tools/vacation/**/*.ts",
    "tools/alerting/openai-cron-auth-guard.ts",
    "tools/covenant/validate_agent_protocol.ts",
    "tools/notifications/flush-digest.ts",
    "tools/openclaw/gateway-env.ts",
    "tools/subagent-watchdog/check-subagents.ts",
    "tools/monitoring/vacation-mode-guard.ts",
    "tools/email/inbox_to_execution.ts",
    "tools/gog/gog-with-env.ts",
    "tools/openclaw/post-update.ts",
    "tools/openclaw/runtime-integrity-check.ts",
    "tools/monitoring/critical-synthetic-probe.ts"
  ]
}
